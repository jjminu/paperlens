# ── PaperLens 환경변수 예시 ──
# 이 파일을 복사해서 .env 로 만든 뒤 값을 채워주세요.
#   cp .env.example .env

# OpenAI API 키 (없으면 mock 요약이 동작합니다)
OPENAI_API_KEY=

# 사용할 모델 (기본값: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible API를 쓸 경우 베이스 URL (예: https://api.together.xyz/v1)
# 비워두면 공식 OpenAI 엔드포인트를 사용합니다.
OPENAI_BASE_URL=

# NCBI Entrez 사용 시 권장: 이메일과 (선택) API 키
# 이메일을 넣으면 PubMed가 더 안정적으로 응답합니다.
NCBI_EMAIL=
NCBI_API_KEY=

# CORS 허용 오리진 (프론트엔드 주소). 쉼표로 여러 개 지정 가능.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
